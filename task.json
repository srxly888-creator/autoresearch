{
  "name": "api_bugfix_assistant",
  "description": "Automatically fix an OpenAI-compatible API helper and validate with local tests.",
  "mutable_paths": [
    "tasks/api_bugfix_assistant/workspace/api_client.py"
  ],
  "evaluate": {
    "command": [
      "__PYTHON__",
      "tasks/api_bugfix_assistant/evaluate.py"
    ],
    "timeout_seconds": 30,
    "score_direction": "maximize"
  },
  "artifacts_dir": "artifacts/api_bugfix_assistant"
}
